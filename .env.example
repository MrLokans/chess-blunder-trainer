# Blunder Tutor Environment Configuration
# Copy this file to .env and configure your settings

# ==============================================================================
# User Configuration (Optional - skips setup screen if set)
# ==============================================================================

# Your Lichess username (leave blank if you don't use Lichess)
LICHESS_USERNAME=

# Your Chess.com username (leave blank if you don't use Chess.com)
CHESSCOM_USERNAME=

# Note: At least one username is required to use Blunder Tutor
# If both are set, puzzles will be merged from both platforms


# ==============================================================================
# Engine Configuration (Optional)
# ==============================================================================

# Stockfish search depth (default: 14)
# Higher values = more accurate analysis but slower
STOCKFISH_DEPTH=14

# Alternative: Use time limit instead of depth (in seconds)
# Uncomment to use time-based analysis instead of depth
# STOCKFISH_TIME=1.0

# Path to Stockfish binary (auto-detected in Docker)
# Only needed for local development if Stockfish is not in PATH
# STOCKFISH_BINARY=/usr/local/bin/stockfish


# ==============================================================================
# Server Configuration (Optional)
# ==============================================================================

# Host to bind the server (default: 0.0.0.0 in Docker, 127.0.0.1 locally)
HOST=0.0.0.0

# Port to bind the server (default: 8000)
PORT=8000


# ==============================================================================
# Demo Mode (Optional)
# ==============================================================================

# Enable read-only demo mode for public hosted instances
# Disables setup, job triggers, settings changes, and data wipe
# DEMO_MODE=false


# ==============================================================================
# Authentication (Optional)
# ==============================================================================

# Auth mode: "none" (single-user, no login) or "credentials" (multi-user
# with username + password). Defaults to "none".
# AUTH_MODE=none

# Required when AUTH_MODE=credentials. Used to HMAC invite codes and CSRF
# tokens. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
# Surrounding whitespace is stripped on load.
# SECRET_KEY=

# Maximum number of user accounts the instance will accept (default: 1).
# MAX_USERS=5

# Forces the session cookie's `Secure` flag. Required when serving over
# HTTPS behind a TLS-terminating reverse proxy (the request scheme reads
# as "http" so the auto-derived default would drop the flag). Set "true"
# in production behind a TLS proxy.
# AUTH_COOKIE_SECURE=true


# ==============================================================================
# Observability — Opt-in Sentry (Optional)
# ==============================================================================
# Off by default. Setting SENTRY_ENABLED=true requires SENTRY_DSN; the app
# fails to boot otherwise (loud, not silent). When disabled, no network
# connections open and no extra state is allocated.

# Master switch. Must be "true" to activate any Sentry integration.
# SENTRY_ENABLED=false

# Sentry project DSN. Required when SENTRY_ENABLED=true.
# SENTRY_DSN=

# Environment tag attached to every event (e.g. "production", "staging",
# "demo"). No auto-derivation — set it explicitly.
# SENTRY_ENVIRONMENT=production

# Release identifier (e.g. CI git SHA). Leave unset for "no release tag".
# SENTRY_RELEASE=

# Per-trace sampling rate, 0.0–1.0. Low-traffic instances keep 1.0.
# /health, /favicon.ico, and /static/* are dropped before sampling.
# SENTRY_TRACES_SAMPLE_RATE=1.0

# When true, Sentry attaches IPs, cookies, request bodies, and the
# authenticated user ID. Default false trims most PII at the SDK boundary.
# SENTRY_SEND_DEFAULT_PII=false

# When true, /health and /static/* are included in trace ingestion.
# Useful only when debugging Docker healthcheck failures or asset routing.
# SENTRY_TRACE_HEALTH=false
