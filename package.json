{
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --config frontend/vite.config.ts",
    "build": "tsc --noEmit --project frontend/tsconfig.json && vite build --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit --project frontend/tsconfig.json",
    "lint": "eslint --config frontend/eslint.config.ts frontend/src/ frontend/tests/",
    "lint:fix": "eslint --config frontend/eslint.config.ts frontend/src/ frontend/tests/ --fix",
    "test": "vitest run --config frontend/vitest.config.ts",
    "test:watch": "vitest --config frontend/vitest.config.ts",
    "test:coverage": "vitest run --config frontend/vitest.config.ts --coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vitest": "^0.5.0",
    "globals": "^16.0.0",
    "jiti": "^2.6.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
